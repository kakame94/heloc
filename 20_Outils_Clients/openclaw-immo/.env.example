# =============================================================================
# OpenClaw Immo — Variables d'environnement
# Copier vers .env et remplir les valeurs.
# NE PAS COMMITTER .env dans Git !
# =============================================================================

# --- Base de donnees ---
DB_PASSWORD=changeme_secure_password

# --- Scraper ---
MAX_PRICE=610000
SCRAPE_INTERVAL_HOURS=4
SCRAPE_MIN_DELAY_SECONDS=3
SCRAPE_MAX_DELAY_SECONDS=8

# --- Hypotheque / Analyse financiere ---
DEFAULT_INTEREST_RATE=0.0499
DEFAULT_DOWN_PAYMENT_PCT=0.10
DEFAULT_AMORTIZATION_YEARS=25
DEFAULT_INSURANCE_ANNUAL=3000
DEFAULT_MAINTENANCE_PCT=0.05
DEFAULT_VACANCY_PCT=0.03

# --- Google Sheets ---
# ID de la feuille (dans l'URL : https://docs.google.com/spreadsheets/d/ID_ICI/edit)
GOOGLE_SHEET_ID=
# Placer le fichier JSON du service account dans ./credentials/gsheets-sa.json

# --- OpenClaw WhatsApp Gateway (gratuit) ---
# Token genere lors du onboard OpenClaw (docker compose run --rm --profile cli openclaw-cli onboard)
OPENCLAW_GATEWAY_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- Bright Data (scraping anti-bot bypass) ---
# Cle API Bright Data (Bearer token)
# Obtenir sur : https://brightdata.com/cp/setting/users
BRIGHTDATA_API_KEY=
# Zone Unlocker (defaut: unlocker)
BRIGHTDATA_ZONE=web_unlocker1
# Activer/desactiver Bright Data (defaut: true)
BRIGHTDATA_ENABLED=true
